# Copy to `.env` (gitignored) and fill in real values, then:  docker compose up -d worker
#
# Reddit "script" app credentials — REQUIRED. Without these the worker cannot
# authenticate to the Reddit API and will fail to produce any posts.
# Create a "script"-type app at https://www.reddit.com/prefs/apps
#   client id  = the string under the app name
#   secret     = the "secret" field
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Optional — override the User-Agent sent to Reddit:
# REDDIT_USER_AGENT=python:reddit-kafka-streamer:v2.0 (streaming worker)

# TimescaleDB credentials — defaults work out of the box; override if changed.
# TIMESCALE_USER=reddit
# TIMESCALE_PASSWORD=reddit
# TIMESCALE_DB=reddit
