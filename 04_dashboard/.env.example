# Copy to `.env` (gitignored) only if you need to override a default below.
# The worker now reads Reddit's PUBLIC RSS feed (/new/.rss) — NO credentials required.

# Optional — override the User-Agent sent to Reddit (it rate-limits generic agents):
# REDDIT_USER_AGENT=python:reddit-rss-streamer:v3.0 (streaming worker)

# TimescaleDB credentials — defaults work out of the box; override if changed.
# TIMESCALE_USER=reddit
# TIMESCALE_PASSWORD=reddit
# TIMESCALE_DB=reddit
